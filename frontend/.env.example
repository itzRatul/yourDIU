# =============================================================================
# yourDIU Frontend — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEXT_PUBLIC_* variables are exposed to the browser — never put secrets here.
# =============================================================================


# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
# Backend URL — change for staging/production
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Set to "true" to use mock data without a running backend (frontend-only test)
NEXT_PUBLIC_USE_MOCK=false


# -----------------------------------------------------------------------------
# SUPABASE (Frontend)
# -----------------------------------------------------------------------------
# Get from: https://supabase.com → Project Settings → API
# Use ANON key only — never service role key here
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key


# -----------------------------------------------------------------------------
# GOOGLE OAUTH
# -----------------------------------------------------------------------------
# Same client ID as backend — used by Supabase Auth on frontend
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Allowed email domain — enforced on both frontend (UI hint) and backend (hard check)
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=diu.edu.bd


# -----------------------------------------------------------------------------
# APP CONFIG
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=yourDIU
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature flags
NEXT_PUBLIC_ENABLE_COMMUNITY=true
NEXT_PUBLIC_ENABLE_PORTAL=false            # Student portal feature toggle
