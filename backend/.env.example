# =============================================================================
# yourDIU Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# =============================================================================


# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------
APP_ENV=development                        # development | production
APP_PORT=8000
APP_SECRET_KEY=change-this-to-a-long-random-secret


# -----------------------------------------------------------------------------
# SUPABASE
# -----------------------------------------------------------------------------
# Get these from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key   # Backend only, never expose to frontend

# Supabase DB direct connection (for pgvector / migrations)
# Get from: Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres


# -----------------------------------------------------------------------------
# GOOGLE OAUTH
# -----------------------------------------------------------------------------
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Allowed domain restriction (@diu.edu.bd) is enforced in backend code.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback


# -----------------------------------------------------------------------------
# GROQ
# -----------------------------------------------------------------------------
# Get from: https://console.groq.com
# Add multiple keys for round-robin (avoids rate limits)
GROQ_API_KEY=your-groq-api-key
GROQ_API_KEY_2=                            # Optional: second key
GROQ_API_KEY_3=                            # Optional: third key
GROQ_MODEL=llama-3.3-70b-versatile


# -----------------------------------------------------------------------------
# GOOGLE GEMINI
# -----------------------------------------------------------------------------
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash


# -----------------------------------------------------------------------------
# WEB SEARCH — Tavily (primary) → Brave (fallback)
# -----------------------------------------------------------------------------
# Tavily: https://app.tavily.com
TAVILY_API_KEY=your-tavily-api-key
TAVILY_DAILY_LIMIT=900                     # Switch to Brave before hitting 1000/month

# Brave Search: https://api.search.brave.com
BRAVE_SEARCH_API_KEY=your-brave-search-api-key


# -----------------------------------------------------------------------------
# EMBEDDINGS
# -----------------------------------------------------------------------------
# Local HuggingFace model (no API key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384


# -----------------------------------------------------------------------------
# RAG SETTINGS
# -----------------------------------------------------------------------------
# Semantic chunking thresholds
SEMANTIC_CHUNK_THRESHOLD=0.75              # Cosine similarity breakpoint
MAX_CHUNK_SIZE=800                         # Max chars after recursive split
CHUNK_OVERLAP=100
RAG_TOP_K=8                                # How many chunks to retrieve per query


# -----------------------------------------------------------------------------
# STUDENT PORTAL (Optional)
# -----------------------------------------------------------------------------
# studentportal.diu.edu.bd — Playwright automation
# Only works from DIU campus network or with VPN
PORTAL_ENABLED=false
PORTAL_URL=https://studentportal.diu.edu.bd


# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
